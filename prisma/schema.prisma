generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  password       String
  avatar         String?
  role           String   @default("user") // "user" | "admin"
  level          String   @default("A1")
  xp             Int      @default(0)
  streak         Int      @default(0)
  coins          Int      @default(0)
  isPremium      Boolean  @default(false)
  premiumPlan    String?
  dailyGoal      Int      @default(20)
  notifications  Boolean  @default(true)
  darkMode       Boolean  @default(false)
  soundEnabled   Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  progress     UserProgress[]
  badges       UserBadge[]
  completions  LessonCompletion[]
  chatMessages ChatMessage[]
  payments     Payment[]
  examAttempts ExamAttempt[]
  certificates Certificate[]
  leaderboard  Leaderboard[]
}

model Level {
  id          String @id @default(cuid())
  code        String @unique
  name        String
  description String
  order       Int
  icon        String

  units    Unit[]
  progress UserProgress[]
}

model Unit {
  id          String @id @default(cuid())
  levelId     String
  title       String
  description String
  order       Int
  icon        String

  level   Level   @relation(fields: [levelId], references: [id], onDelete: Cascade)
  lessons Lesson[]
}

model Lesson {
  id          String  @id @default(cuid())
  unitId      String
  title       String
  description String
  type        String
  content     String
  order       Int
  xpReward    Int     @default(10)
  duration    Int     @default(5)

  unit        Unit             @relation(fields: [unitId], references: [id], onDelete: Cascade)
  completions LessonCompletion[]
}

model UserProgress {
  id         String   @id @default(cuid())
  userId     String
  levelId    String
  progress   Int      @default(0)
  completed  Boolean  @default(false)
  updatedAt  DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  level Level @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@unique([userId, levelId])
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  name      String
  icon      String
  earnedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model LessonCompletion {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  score     Int
  xpEarned  Int
  completedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyChallenge {
  id            String @id @default(cuid())
  date          String
  type          String
  question      String
  options       String
  correctAnswer String
  xpReward      Int    @default(15)

  @@unique([date, type])
}

model Leaderboard {
  id     String @id @default(cuid())
  userId String
  period String
  score  Int
  rank   Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
}

model Payment {
  id              String   @id @default(cuid())
  userId          String
  planId          String   // 'essentiel' | 'complet' | 'integral'
  amount          Int      // Amount in FCFA
  currency        String   @default("XOF") // FCFA ISO code
  paymentMethod   String   // 'orange_money' | 'mtn_momo' | 'wave' | 'card'
  phoneNumber     String?  // For mobile money
  status          String   @default("pending") // 'pending' | 'pending_validation' | 'processing' | 'success' | 'failed' | 'expired'
  providerRef     String?  // Reference from FedaPay/CinetPay
  providerName    String?  // 'fedapay' | 'cinetpay' | 'demo' | 'direct'
  trialStart      DateTime? // When the 3-day trial begins
  trialEnd        DateTime? // When the 3-day trial ends
  paidAt          DateTime? // When the payment was confirmed
  expiresAt       DateTime? // Payment link expiration
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)
}

model ExamAttempt {
  id            String   @id @default(cuid())
  userId        String
  level         String   // A1, A2, B1, B2, C1, C2
  score         Int      // 0-100
  totalQuestions Int
  correctAnswers Int
  passed        Boolean  // true if score >= 70
  xpEarned      Int      @default(0)
  completedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, level])
}

model Certificate {
  id               String   @id @default(cuid())
  userId           String
  certificateId    String   @unique   // Unique public ID (e.g. YOELANG-A1-2025-001234)
  level            String   // CEFR level: A1, A2, B1, B2, C1, C2
  examScore        Int      // Score obtained in the exam (0-100)
  totalQuestions   Int      // Total questions in the exam
  correctAnswers   Int      // Correct answers in the exam
  totalLessons     Int      // Total lessons in the level at time of completion
  completedLessons Int      // Lessons completed at time of certification
  avgLessonScore   Int      @default(0) // Average lesson score
  xpAtCompletion   Int      @default(0) // XP at the time of certification
  userName         String   @default("Apprenant") // Name as it appeared when certificate was earned
  issuedAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([userId, level])
  @@index([certificateId])
}
